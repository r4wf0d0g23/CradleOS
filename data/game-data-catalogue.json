  "refuge": [
    {
      "typeID": 1015358,
      "label": "Refuge (description)",
      "text": "The <b>Refuge</b> serves as your field base. It stores your ships, and within its range, you can manage your <b>Shell</b> [Alt + C] and <b>Ascend</b>. It also allows you to refit your ship using the <b>Fitting</b> menu [Alt + F].\r\n\r\nBuild it [B], and place it close to your other <b>Assemblies</b> for more efficient operations.\r\n\r\nRequired <a href=\"showinfo:77810\">Platinum-Palladium Matrix</a> is extracted from <a href=\"showinfo:91375\">Slag</a> typically found closer to the star.",
      "desc": null,
      "group": "Refuge"
    }
  ],
